// Collections
show("\nCollections:")
let stack = collections.Stack()
stack.push(10)
stack.push(20)
stack.push(30)
show("  Stack top: " + str(stack.peek()))
show("  Pop: " + str(stack.pop()))
show("  Stack size: " + str(stack.size()))

let queue = collections.Queue()
queue.enqueue("first")
queue.enqueue("second")
queue.enqueue("third")
show("  Queue front: " + queue.front())
show("  Dequeue: " + queue.dequeue())

// JSON
