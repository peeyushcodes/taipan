{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "taipan",
  "scopeName": "source.taipan",
  "fileTypes": ["tp"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#builtins" },
    { "include": "#types" },
    { "include": "#operators" },
    { "include": "#functions" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.taipan",
          "match": "//.*$"
        },
        {
          "name": "comment.block.taipan",
          "begin": "/\\*",
          "end": "\\*/",
          "beginCaptures": { "0": { "name": "punctuation.definition.comment.begin.taipan" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.comment.end.taipan"   } }
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.taipan",
          "begin": "\"",
          "end": "\"",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.taipan" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.string.end.taipan"   } },
          "patterns": [
            {
              "name": "constant.character.escape.taipan",
              "match": "\\\\[ntr\\\\\"'0]"
            }
          ]
        },
        {
          "name": "string.quoted.single.taipan",
          "begin": "'",
          "end": "'",
          "beginCaptures": { "0": { "name": "punctuation.definition.string.begin.taipan" } },
          "endCaptures":   { "0": { "name": "punctuation.definition.string.end.taipan"   } },
          "patterns": [
            {
              "name": "constant.character.escape.taipan",
              "match": "\\\\[ntr\\\\\"'0]"
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.taipan",
          "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.taipan",
          "match": "\\b[0-9][0-9_]*\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.taipan",
          "match": "\\b(if|else|while|for|repeat|break|continue|return|try|catch)\\b"
        },
        {
          "name": "keyword.declaration.taipan",
          "match": "\\b(let|const|func|class|extends)\\b"
        },
        {
          "name": "keyword.other.taipan",
          "match": "\\b(import|spawn|wait|in|and|or|not|ai|self|super|new|null)\\b"
        },
        {
          "name": "constant.language.boolean.taipan",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "constant.language.null.taipan",
          "match": "\\bnull\\b"
        }
      ]
    },
    "builtins": {
      "name": "support.function.builtin.taipan",
      "match": "\\b(show|input|len|type|int|float|str|bool|range|list|set|map|abs|min|max|sum|round|sorted|reversed|assert|format|print|chr|ord|hex|bin|exit)(?=\\s*\\()"
    },
    "types": {
      "name": "support.type.taipan",
      "match": "(?<=:\\s*)\\b(Int|Float|String|Bool|List|Map|Set|Tuple|Null|Any|Void)\\b"
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arithmetic.taipan",
          "match": "(\\*\\*|//|[+\\-*/%])"
        },
        {
          "name": "keyword.operator.comparison.taipan",
          "match": "(==|!=|<=|>=|<|>)"
        },
        {
          "name": "keyword.operator.assignment.taipan",
          "match": "(\\+=|-=|\\*=|/=|=)"
        },
        {
          "name": "keyword.operator.other.taipan",
          "match": "(->|\\.\\.|!)"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.taipan",
          "match": "(?<=func\\s)\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "entity.name.class.taipan",
          "match": "(?<=class\\s)\\b[A-Z][a-zA-Z0-9_]*\\b"
        },
        {
          "name": "meta.function-call.taipan",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*(?=\\s*\\()"
        }
      ]
    },
    "identifiers": {
      "name": "variable.other.taipan",
      "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.brackets.taipan", "match": "[{}\\[\\]()]" },
        { "name": "punctuation.separator.taipan", "match": "[,;:]"       },
        { "name": "punctuation.accessor.taipan",  "match": "\\."         }
      ]
    }
  }
}
